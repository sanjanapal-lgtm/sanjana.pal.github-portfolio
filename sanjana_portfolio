  .tl-heading { font-size:.72rem; font-weight:700; letter-spacing:.25em; text-transform:uppercase; color:var(--gold); margin-bottom:2rem; }
  .tl { list-style:none; }
  .tl-item { display:grid; grid-template-columns:90px 1fr; gap:1.5rem; padding:1.5rem 0; border-bottom:1px solid var(--bd-dark); }
