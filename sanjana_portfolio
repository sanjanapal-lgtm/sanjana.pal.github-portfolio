  .cta-eyebrow { font-size:.72rem; font-weight:700; letter-spacing:.25em; text-transform:uppercase; color:var(--gold); margin-bottom:1.5rem; }
  .cta-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2.8rem,5vw,5rem); font-weight:300; line-height:1.1; color:var(--ink); margin-bottom:1rem; }
  .cta-title em { font-style:italic; color:var(--gold); }
  .cta-sub { font-size:.87rem; color:var(--text-muted); margin-bottom:3rem; max-width:480px; margin-left:auto; margin-right:auto; line-height:1.7; }
  .cta-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

  /* FOOTER */
  footer { background:#060504; display:flex; justify-content:space-between; align-items:center; padding:2rem 4rem; border-top:1px solid rgba(255,255,255,.05); flex-wrap:wrap; gap:1rem; }
