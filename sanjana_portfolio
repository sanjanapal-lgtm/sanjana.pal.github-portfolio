  .proj-quote { border-left:3px solid var(--gold); padding-left:1.2rem; margin-top:2rem; font-family:'Cormorant Garamond',serif; font-size:1.1rem; font-style:italic; line-height:1.7; color:var(--ink); }
  .proj-imgs { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-top:2.5rem; }
  .proj-img-ph { aspect-ratio:4/3; background:#e8e4dc; display:flex; align-items:center; justify-content:center; font-size:.68rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:rgba(11,11,11,.22); border:1px dashed rgba(11,11,11,.15); }
