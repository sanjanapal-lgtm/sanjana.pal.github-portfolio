  .btn-pd { display:inline-block; padding:.85rem 2rem; background:var(--gold); color:var(--ink); font-family:'Syne',sans-serif; font-size:.75rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; text-decoration:none; transition:background .25s,transform .2s; }
