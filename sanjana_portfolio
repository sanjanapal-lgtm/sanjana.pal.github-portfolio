  .exp-card:nth-child(2) { transition-delay:.12s; }
  .exp-card:nth-child(3) { transition-delay:.24s; }
  .ec-num { font-family:'Cormorant Garamond',serif; font-size:.85rem; color:var(--gold); font-weight:600; letter-spacing:.1em; margin-bottom:2rem; }
  .ec-title { font-family:'Cormorant Garamond',serif; font-size:1.7rem; font-weight:400; line-height:1.2; color:var(--white); margin-bottom:1.2rem; }
  .ec-body { font-size:.87rem; line-height:1.85; color:rgba(255,255,255,.52); }
  .ec-rule { margin-top:1.8rem; padding-top:1.2rem; border-top:1px solid rgba(184,147,90,.25); font-size:.68rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); }

  /* PROJECT */
  .project { background:var(--paper); padding:8rem 4rem; }
  .proj-inner { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:start; opacity:0; transform:translateY(30px); transition:opacity .8s,transform .8s; }
  .proj-inner.vis { opacity:1; transform:translateY(0); }
  .proj-tag { display:inline-block; font-size:.68rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; background:var(--ink); color:var(--gold); padding:.45rem 1rem; margin-bottom:1.5rem; }
  .proj-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,3vw,2.8rem); font-weight:400; line-height:1.1; color:var(--ink); margin-bottom:1.5rem; }
  .proj-overview { font-size:.9rem; line-height:1.9; color:var(--text-muted); }
