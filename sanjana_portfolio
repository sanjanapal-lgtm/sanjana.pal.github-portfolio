  .tags { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:2.5rem; }
  .tag { font-size:.68rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; border:1px solid rgba(255,255,255,.18); color:rgba(255,255,255,.55); padding:.4rem .9rem; transition:border-color .2s,color .2s; cursor:default; }
  .tag:hover { border-color:var(--gold); color:var(--gold); }
  .about-r { opacity:0; transform:translateX(30px); transition:opacity .8s .2s,transform .8s .2s; }
