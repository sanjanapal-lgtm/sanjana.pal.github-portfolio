  .hero-left {
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 9rem 3rem 6rem 4rem; background: var(--ink);
  }
  .hero-eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 2rem; opacity:0; transform:translateY(20px); animation: fu 0.8s 0.2s forwards; }
  .hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.2rem,5vw,5.2rem); font-weight: 300; line-height: 1.05; opacity:0; transform:translateY(30px); animation: fu 0.9s 0.4s forwards; }
  .hero-title em { font-style: italic; color: var(--gold-light); }
  .hero-sub { margin-top: 2rem; font-size: 0.9rem; line-height: 1.85; color: rgba(255,255,255,0.58); max-width: 430px; opacity:0; transform:translateY(20px); animation: fu 0.9s 0.6s forwards; }
  .hero-tagline { margin-top: 1.5rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); opacity:0; transform:translateY(20px); animation: fu 0.9s 0.72s forwards; }
  .hero-ctas { display: flex; gap: 1rem; margin-top: 3rem; opacity:0; transform:translateY(20px); animation: fu 0.9s 0.85s forwards; }

  .hero-right { background: var(--ink-2); position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .hero-right::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(-45deg,transparent,transparent 50px,rgba(184,147,90,0.022) 50px,rgba(184,147,90,0.022) 51px); }
  .hero-mono { font-family: 'Cormorant Garamond', serif; font-size: clamp(12rem,20vw,18rem); font-weight: 300; color: rgba(184,147,90,0.07); user-select: none; pointer-events: none; letter-spacing: -0.05em; opacity:0; animation: fi 2s 0.5s forwards; }
  .hero-loc { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.28); position: absolute; bottom: 3rem; left: 3rem; opacity:0; animation: fi 1s 1.4s forwards; }
  .hero-badge { position: absolute; top: 8rem; right: 3rem; background: var(--gold); color: var(--ink); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; padding: 0.5rem 1rem; opacity:0; animation: fi 1s 1.6s forwards; }

  /* BUTTONS */
  .btn-p { display:inline-block; padding:.85rem 2rem; background:var(--gold); color:var(--ink); font-family:'Syne',sans-serif; font-size:.75rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; text-decoration:none; transition:background .25s,transform .2s; }
  .btn-p:hover { background:var(--gold-light); transform:translateY(-2px); }
  .btn-g { display:inline-block; padding:.85rem 2rem; border:1px solid rgba(255,255,255,.25); color:var(--white); font-family:'Syne',sans-serif; font-size:.75rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; text-decoration:none; transition:border-color .25s,color .25s,transform .2s; }
