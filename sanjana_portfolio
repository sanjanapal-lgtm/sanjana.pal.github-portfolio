  .tl-year { font-size:.72rem; font-weight:700; color:var(--gold); letter-spacing:.1em; padding-top:.2rem; }
  .tl-role { font-size:.95rem; font-weight:500; color:var(--white); line-height:1.3; }
  .tl-place { font-size:.8rem; color:rgba(255,255,255,.38); margin-top:.3rem; }

  /* CTA */
  .cta { background:var(--paper); padding:8rem 4rem; text-align:center; position:relative; overflow:hidden; }
  .cta::before { content:'SP'; font-family:'Cormorant Garamond',serif; font-size:30vw; font-weight:300; color:rgba(184,147,90,.055); position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none; user-select:none; white-space:nowrap; }
  .cta-inner { position:relative; z-index:2; opacity:0; transform:translateY(30px); transition:opacity .8s,transform .8s; }
