  .foot-links { display:flex; gap:2rem; }
  .foot-links a { font-size:.72rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:rgba(255,255,255,.32); text-decoration:none; transition:color .2s; }
  .foot-links a:hover { color:var(--gold); }

  @keyframes fu { to { opacity:1; transform:translateY(0); } }
  @keyframes fi { to { opacity:1; } }
</style>
</head>
